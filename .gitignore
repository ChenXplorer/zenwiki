# ─── Node / frontend build ──────────────────────────────────────────
web/node_modules/
web/dist/
web/.vite/
web/tsconfig.tsbuildinfo

# Built frontend artifacts under src/zenwiki/static/ ARE tracked on
# purpose: they ship with the Python wheel and let users `pip install
# git+...` without needing Node. Rebuild with `cd web && npm run build`
# before committing frontend changes. Accept the diff churn.

# ─── User wiki workspace ────────────────────────────────────────────
# my-wiki/ is a personal knowledge base; users run `zenwiki init <dir>`
# to create their own. Never commit one into this repo.
my-wiki/

